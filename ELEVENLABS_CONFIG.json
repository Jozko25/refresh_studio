{
  "type": "webhook",
  "name": "refresh-booking-system",
  "description": "Nástroj na rezerváciu v REFRESH clinic - Bratislava a Pezinok - POVINNÉ ZAVOLAŤ PRI KAŽDEJ REZERVÁCII",
  "disable_interruptions": false,
  "force_pre_tool_speech": "auto",
  "assignments": [],
  "api_schema": {
    "url": "https://refreshstudio-production.up.railway.app/api/elevenlabs",
    "method": "POST",
    "path_params_schema": [],
    "query_params_schema": [],
    "request_body_schema": {
      "id": "body",
      "type": "object",
      "description": "Vytvorenie novej rezervácie v REFRESH clinic",
      "properties": [
        {
          "id": "tool_name",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Názov funkcie - vždy 'refresh_booking'",
          "dynamic_variable": "",
          "constant_value": "refresh_booking",
          "required": false
        },
        {
          "id": "service",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Názov služby v slovenčine - systém automaticky nájde z 339+ služieb",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "location",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Miesto: 'bratislava' alebo 'pezinok' - vždy sa opýtať zákazníka",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "age",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Vek zákazníka - POVINNÝ pre pleťové ošetrenia (hydrafacial, peeling) - vždy sa opýtať",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "date",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Dátum vo formáte DD.MM.YYYY - nechať prázdne pre najskorší termín",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "time",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Čas vo formáte HH:MM - len ak zákazník požaduje konkrétny čas",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "name",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Meno a priezvisko zákazníka - potrebné pri potvrdení rezervácie",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "phone",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Telefónne číslo zákazníka - potrebné pri potvrdení rezervácie",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "email",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Email zákazníka - nepovinný ale odporúčaný",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "worker",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Meno personálu - použiť ak zákazník požaduje konkrétnu osobu",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        },
        {
          "id": "skip_slots",
          "type": "integer",
          "value_type": "llm_prompt",
          "description": "Výber termínu: 0=najskorší, 1=druhý, 2=tretí - pre alternatívne časy",
          "dynamic_variable": "",
          "constant_value": "",
          "required": false
        }
      ],
      "required": false,
      "value_type": "llm_prompt"
    },
    "request_headers": [
      {
        "type": "value",
        "name": "Content-Type",
        "value": "application/json"
      }
    ],
    "auth_connection": null
  },
  "response_timeout_secs": 25,
  "dynamic_variables": {
    "dynamic_variable_placeholders": {}
  }
}