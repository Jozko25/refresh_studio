{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": [
            "nodejs-20_x",
            "libnss3",
            "libatk-bridge-2-0",
            "libdrm2",
            "libxkbcommon0",
            "libgbm1"
          ]
        },
        "install": {
          "cmds": [
            "npm ci",
            "npx playwright install chromium",
            "npx playwright install-deps chromium"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}