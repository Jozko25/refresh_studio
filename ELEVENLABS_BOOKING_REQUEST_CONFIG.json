          "constant_value": "",
          "required": true
        },
        {
          "id": "customer_name",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Meno a priezvisko zákazníka",
          "dynamic_variable": "",
          "constant_value": "",
          "required": true
        },
        {
          "id": "phone",
          "type": "string",
          "value_type": "llm_prompt",
          "description": "Telefónne číslo zákazníka",
          "dynamic_variable": "",
          "constant_value": "",
          "required": true
