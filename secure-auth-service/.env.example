# SECURITY CONFIGURATION
MASTER_KEY=your-very-long-random-master-key-min-32-chars
API_KEY=your-api-key-for-railway-communication
SERVICE_PORT=3001

# ENCRYPTED CREDENTIALS (use setup.js to generate)
ENCRYPTED_USERNAME=
ENCRYPTED_PASSWORD=

# RAILWAY CONFIGURATION
RAILWAY_API_URL=https://refreshstudio-production.up.railway.app/api/auth/update-cookie
RAILWAY_API_KEY=must-match-railway-env-var

# SECURITY SETTINGS
ALLOWED_IPS=127.0.0.1,your-railway-ip
MAX_REQUESTS_PER_HOUR=10
ENABLE_AUDIT_LOG=true

# REFRESH SCHEDULE (in hours)
REFRESH_INTERVAL_HOURS=11

# EMAIL ALERTS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL=admin@example.com

# FACILITIES
FACILITY_BRATISLAVA=refresh-laserove-a-esteticke-studio-zu0yxr5l
FACILITY_PEZINOK=refresh-laserove-a-esteticke-studio